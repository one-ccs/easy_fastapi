"""角色 service（自动生成）。"""
from easy_fastapi import FailureException, Result
from app import schemas, models


async def get(id: int):
    role = await models.Role.by_id(id)
    if not role:
        raise FailureException('Role not found')
    return Result(data=role)


async def add(role_data: schemas.RoleCreate):
    if await models.Role.exists(role=role_data.role):
        raise FailureException('Role already exists')
    role = await models.Role.create(**role_data.model_dump())
    return Result(data=role)


async def modify(role_data: schemas.RoleModify):
    role = await models.Role.by_id(role_data.id)
    if not role:
        raise FailureException('Role not found')
    role = await models.Role.update_from_dict(role, role_data.model_dump(exclude={'id'}, exclude_unset=True))
    return Result(data=role)


async def delete(ids: list[int]):
    count = await models.Role.delete_by_ids(ids)
    return Result(data=count)


async def page(page_query: schemas.PageQuery):
    result = await models.Role.paginate(page_query.page, page_query.size)
    return Result(data=result)
