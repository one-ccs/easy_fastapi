[project]
name = "{{ options.package_name }}"
version = "0.1.0"
description = "{{ options.project_name }} — generated by easy-fastapi"
requires-python = ">=3.10"
dependencies = [
    "easy-fastapi>=1.0.0",
    "uvicorn>=0.30.0",
{% if options.database and options.orm == 'tortoise' %}
    "tortoise-orm>=0.21.7",
{% endif %}
{% if options.database and options.orm == 'sqlalchemy' %}
    "sqlalchemy>=2.0.0",
{% endif %}
{% if options.database and options.orm == 'sqlmodel' %}
    "sqlmodel>=0.0.21",
{% endif %}
{% if options.database and options.db_dialect == 'mysql' %}
    "asyncmy>=0.2.9",
{% endif %}
{% if options.database and options.db_dialect == 'postgres' %}
    "asyncpg>=0.29.0",
{% endif %}
{% if options.database and options.db_dialect == 'sqlite' %}
    "aiosqlite>=0.20.0",
{% endif %}
{% if options.migration and options.orm == 'tortoise' %}
    "aerich>=0.8.0",
{% endif %}
{% if options.migration and options.orm != 'tortoise' %}
    "alembic>=1.13.0",
{% endif %}
{% if options.auth %}
    "pwdlib[argon2]>=0.2.0",
    "pyjwt>=2.9.0",
    "email-validator>=2.3.0",
{% endif %}
{% if options.redis %}
    "redis>=5.2.0",
{% endif %}
]

[dependency-groups]
dev = [
    "pytest>=8.0.0",
    "httpx>=0.28.0",
]
